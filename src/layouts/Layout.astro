---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Massage Bellevue WA | All Star Massage and Spa | Lake Bellevue",
  description = "All Star Massage and Spa — Bellevue's premier lakeside massage and spa. Medical massage, deep tissue, hot stone, facials & body treatments on Lake Bellevue. Insurance accepted. Call 425.452.1772."
} = Astro.props;

const currentPath = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>
<meta name="description" content={description}>
<meta name="keywords" content="massage Bellevue WA, medical massage Bellevue, massage therapy Bellevue Washington, deep tissue massage Bellevue, hot stone massage Bellevue, spa Bellevue WA, Lake Bellevue spa, facials Bellevue WA, massage insurance Bellevue, massage near me Bellevue, Eastside massage therapy">
<meta name="robots" content="index, follow">
<link rel="canonical" href="https://www.allstarlakespa.com">
<meta property="og:type" content="website">
<meta property="og:url" content="https://www.allstarlakespa.com/">
<meta property="og:title" content="All Star Massage and Spa | Bellevue WA | Lake Bellevue">
<meta property="og:description" content="Heal. Restore. Renew. Bellevue's lakeside massage and spa. Medical massage, hot stone, facials, body treatments. Insurance accepted.">
<meta property="og:image" content="https://images.unsplash.com/photo-1600334089648-b0d9d3028eb2?w=1200">
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml;base64,">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
<script type="application/ld+json" set:html={`{
  "@context":"https://schema.org",
  "@type":"MassageTherapist",
  "name":"All Star Massage and Spa",
  "alternateName":"All Star Lake Spa",
  "description":"Bellevue's premier lakeside massage and spa. Medical massage, wellness massage, facials and body treatments on Lake Bellevue. Insurance accepted.",
  "url":"https://www.allstarlakespa.com",
  "telephone":"+14254521772",
  "priceRange":"\$\$",
  "address":{"@type":"PostalAddress","streetAddress":"9 Lake Bellevue Drive, Suite 112","addressLocality":"Bellevue","addressRegion":"WA","postalCode":"98005","addressCountry":"US"},
  "geo":{"@type":"GeoCoordinates","latitude":47.5980,"longitude":-122.1875},
  "openingHoursSpecification":[
    {"@type":"OpeningHoursSpecification","dayOfWeek":["Monday"],"opens":"09:00","closes":"19:00"},
    {"@type":"OpeningHoursSpecification","dayOfWeek":["Tuesday","Wednesday","Thursday"],"opens":"10:00","closes":"21:00"},
    {"@type":"OpeningHoursSpecification","dayOfWeek":["Friday"],"opens":"09:00","closes":"19:00"},
    {"@type":"OpeningHoursSpecification","dayOfWeek":["Saturday"],"opens":"09:00","closes":"21:00"}
  ],
  "areaServed":[{"@type":"City","name":"Bellevue"},{"@type":"City","name":"Kirkland"},{"@type":"City","name":"Issaquah"},{"@type":"City","name":"Mercer Island"},{"@type":"City","name":"Sammamish"},{"@type":"City","name":"Redmond"}],
  "hasOfferCatalog":{"@type":"OfferCatalog","name":"Massage and Spa Services","itemListElement":[
    {"@type":"Offer","itemOffered":{"@type":"Service","name":"Medical Massage Bellevue WA"}},
    {"@type":"Offer","itemOffered":{"@type":"Service","name":"Deep Tissue Massage Bellevue"}},
    {"@type":"Offer","itemOffered":{"@type":"Service","name":"Hot Stone Massage Bellevue"}},
    {"@type":"Offer","itemOffered":{"@type":"Service","name":"Facial Bellevue WA"}},
    {"@type":"Offer","itemOffered":{"@type":"Service","name":"Spa Packages Bellevue"}}
  ]},
  "aggregateRating":{"@type":"AggregateRating","ratingValue":"4.1","reviewCount":"136","bestRating":"5"},
  "founder":{"@type":"Person","name":"Starla Schwartz","jobTitle":"Licensed Massage Practitioner, Spa Director"},
  "foundingDate":"2006"
}`} />
</head>
<body>
<a href="#main-content" class="skip-link">Skip to content</a>
<Nav currentPath={currentPath} />
<slot />
<Footer />
<script is:inline>
function toggleMob() {
  const m = document.getElementById('mobMenu');
  if (!m) return;
  const open = m.classList.toggle('open');
  m.setAttribute('aria-hidden', String(!open));
  const btn = document.querySelector('.ham');
  if (btn) btn.setAttribute('aria-expanded', String(open));
}
document.addEventListener('DOMContentLoaded', () => {
  document.addEventListener('click', (e) => {
    const m = document.getElementById('mobMenu');
    if (!m || !m.classList.contains('open')) return;
    if (!m.contains(e.target) && !e.target.closest('.ham')) {
      m.classList.remove('open');
      m.setAttribute('aria-hidden', 'true');
      document.querySelector('.ham')?.setAttribute('aria-expanded', 'false');
    }
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      const m = document.getElementById('mobMenu');
      if (m?.classList.contains('open')) {
        m.classList.remove('open');
        m.setAttribute('aria-hidden', 'true');
        const btn = document.querySelector('.ham');
        btn?.setAttribute('aria-expanded', 'false');
        btn?.focus();
      }
    }
  });
});
</script>
</body>
</html>
