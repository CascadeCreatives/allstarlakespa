---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Page Not Found | All Star Massage and Spa">
  <main class="page" id="main-content" style="display:flex;align-items:center;justify-content:center;min-height:60vh;text-align:center">
    <div>
      <p class="lbl">404 — Page Not Found</p>
      <h1 class="h2" style="margin:1rem 0">This page has moved<br>or doesn't exist</h1>
      <div class="rule rc"></div>
      <div style="display:flex;gap:1rem;justify-content:center;margin-top:2rem;flex-wrap:wrap">
        <a href="/" class="btn btn-p">Go Home</a>
        <a href="/services" class="btn btn-o">Our Services</a>
        <a href="/contact" class="btn btn-o">Contact Us</a>
      </div>
    </div>
  </main>
</Layout>
