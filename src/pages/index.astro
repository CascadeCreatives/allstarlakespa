---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Massage Bellevue WA | All Star Massage and Spa | Lake Bellevue">
  <main class="page" id="main-content">
<section class="hero" aria-label="Welcome">
    <div class="hero-l">
      <p class="hero-ey">Bellevue's Lakeside Healing Sanctuary · Est. 2006</p>
      <h1 class="hero-h">Heal.<br><em>Restore.</em><br>Renew.</h1>
      <p class="hero-tl">On Lake Bellevue.</p>
      <p class="hero-sub">Medical massage, wellness therapies, and restorative skin care — by state-licensed professionals in a serene lakeside setting. Most insurance accepted.</p>
      <div class="hero-ctas">
        <a href="https://www.secure-booker.com/allstarmassage/MakeAppointment/Search.aspx" target="_blank" rel="noopener" class="btn btn-p btn-lg">Book an Appointment</a>
        <a href="/gift" class="btn btn-o btn-lg">Send a Gift Card</a>
      </div>
      <p class="hero-ph">Call us: <a href="tel:4254521772">425.452.1772</a> &nbsp;·&nbsp; Mon &amp; Fri 9am–7pm · Tue–Thu 10am–9pm · Sat 9am–9pm</p>
    </div>
    <div class="hero-r">
      <img src="photos/photo-hero.jpg"
        alt="Serene spa treatment room at All Star Massage and Spa on Lake Bellevue, Bellevue WA"
        width="900" height="700" loading="eager" fetchpriority="high">
      <div class="hero-badge" aria-label="20 years healing Bellevue">
        <strong>20</strong><span>Years healing Bellevue</span>
      </div>
    </div>
  </section>

  <div class="trust" role="complementary" aria-label="Quick facts">
    <div class="trust-i">
      <span>✦ Medical Massage</span><span class="td">|</span>
      <span>✦ Insurance Accepted</span><span class="td">|</span>
      <span>✦ On Lake Bellevue</span><span class="td">|</span>
      <span>✦ 20 Years in Bellevue</span><span class="td">|</span>
      <span>✦ Mon &amp; Fri 9–7 · Tue–Thu 10–9 · Sat 9–9</span><span class="td">|</span>
      <a href="tel:4254521772" style="color:inherit">✦ 425.452.1772</a>
    </div>
  </div>

  <div class="strip" aria-label="Spa services gallery">
    <div class="strip-i">
      <img src="photos/photo-strip-1.jpg"
        alt="Relaxing massage therapy treatment Bellevue WA" width="400" height="270" loading="lazy">
      <div class="strip-lbl">Massage Therapy</div>
    </div>
    <div class="strip-i">
      <img src="photos/photo-strip-2.jpg"
        alt="Facial skin care treatment Bellevue WA spa" width="400" height="270" loading="lazy">
      <div class="strip-lbl">Facials &amp; Skin Care</div>
    </div>
    <div class="strip-i">
      <img src="photos/photo-strip-3.jpg"
        alt="Deep tissue massage therapy Bellevue WA" width="400" height="270" loading="lazy">
      <div class="strip-lbl">Deep Tissue Massage</div>
    </div>
    <div class="strip-i">
      <img src="photos/photo-strip-4.jpg"
        alt="Lake Bellevue Bellevue Washington — view from All Star Massage and Spa" width="400" height="270" loading="lazy">
      <div class="strip-lbl">Lake Bellevue View</div>
    </div>
  </div>

  <section class="sec" aria-labelledby="svc-h">
    <div class="c">
      <span class="lbl">Massage &amp; Spa Services · Bellevue, WA</span>
      <h2 class="h2" id="svc-h">Thoughtfully curated<br><em>healing experiences</em></h2>
      <div class="rule"></div>
      <p class="body-s" style="max-width:500px">Every treatment is customized by our state-licensed therapists and estheticians. Whether you're healing, recovering, or restoring — we have a path for you.</p>
    </div>
    <div class="svc-grid" role="list">
      <a href="/services" class="svc-c" role="listitem">
        <img src="https://images.unsplash.com/photo-1516302752625-fcc3c50ae61f?w=600&auto=format&fit=crop&q=75" alt="Medical massage therapy pain relief Bellevue WA" width="600" height="155" loading="lazy">
        <h3>Medical Massage</h3>
        <p>Insurance-billed therapeutic massage for pain relief and rehabilitation. In-network with Regence, Premera, BCBS, Aetna, United Healthcare, Kaiser, and more.</p>
        <span class="svc-lnk">Learn more →</span>
      </a>
      <a href="/services" class="svc-c" role="listitem">
        <img src="photos/photo-svc-wellness.jpg" alt="Wellness massage Bellevue WA spa" width="600" height="155" loading="lazy">
        <h3>Wellness &amp; Spa Massage</h3>
        <p>Hot stone, deep tissue, Swedish, sports, prenatal — our most popular treatments melt stress and renew your body, mind, and spirit.</p>
        <span class="svc-lnk">Learn more →</span>
      </a>
      <a href="/services" class="svc-c" role="listitem">
        <img src="photos/photo-strip-1.jpg" alt="Facial skin care treatment Bellevue WA esthetician" width="600" height="155" loading="lazy">
        <h3>Facials &amp; Skin Care</h3>
        <p>Personalized facials including our signature European Facial. Expert skin care treatments tailored to your skin type. Glow from the inside out.</p>
        <span class="svc-lnk">Learn more →</span>
      </a>
      <a href="/services" class="svc-c" role="listitem">
        <img src="https://images.unsplash.com/photo-1471897488648-5eae4ac6686b?w=600&auto=format&fit=crop&q=75" alt="Body treatment spa Bellevue WA Pacific Northwest" width="600" height="155" loading="lazy">
        <h3>Body Treatments</h3>
        <p>Restorative body wraps, mud treatments, and exfoliating scrubs using M'Lis products. Head-to-toe detox and nourishment.</p>
        <span class="svc-lnk">Learn more →</span>
      </a>
      <a href="/services" class="svc-c" role="listitem">
        <img src="photos/photo-svc-packages.jpg" alt="Starlight spa package Lake Bellevue" width="600" height="155" style="object-position:center top" loading="lazy">
        <h3>Starlight Spa Packages</h3>
        <p>Curated multi-treatment packages — massage, facial, body care combined. Perfect for birthdays, anniversaries, or a full restorative day on the lake.</p>
        <span class="svc-lnk">Learn more →</span>
      </a>
      <a href="/specials" class="svc-c" role="listitem">
        <img src="photos/photo-svc-specials.jpg" alt="Spa day special Bellevue WA monthly offer" width="600" height="155" loading="lazy">
        <h3>Monthly Specials</h3>
        <p>This month: <strong>Take a Spa Day</strong> — foot soak, paraffin dip, facial, scalp massage, beverage and snack. Just $99. A new offer every month.</p>
        <span class="svc-lnk">View this month's specials →</span>
      </a>
    </div>
  </section>

  <div class="gstrip">
    <div class="c gstrip-i">
      <div>
        <h2>The gift of <em>healing</em></h2>
        <div class="rule"></div>
        <p>The perfect present for any occasion. Instant digital gift certificates delivered by email — for any service, any amount.</p>
      </div>
      <div class="gstrip-r">
        <a href="https://allstarlakespa.boomtime.com/lgift" target="_blank" rel="noopener" class="btn btn-p btn-lg">Purchase Instantly Online →</a>
        <p style="font-size:.72rem;color:var(--stone)">Delivered by email · Any amount · Any service</p>
      </div>
    </div>
  </div>

  <section class="sec rev" aria-labelledby="rev-h">
    <div class="c">
      <span class="lbl tc">What Bellevue Guests Say</span>
      <h2 class="h2 tc" id="rev-h">Voices from the <em>lake</em></h2>
      <div class="rule rc"></div>
      <div class="rev-grid">
        <article class="rev-c">
          <div class="rev-stars" aria-label="5 out of 5 stars" role="img">★★★★★</div>
          <p class="rev-text">I've been going here for massages with Starla for the last six months and continue to be impressed. The waiting room is delightful — sit back, have a cup of tea, and look at the beautiful lake while you wait.</p>
          <p class="rev-by">— Verified Guest · Yelp</p>
        </a>
        <article class="rev-c">
          <div class="rev-stars" aria-label="5 out of 5 stars" role="img">★★★★★</div>
          <p class="rev-text">I couldn't stand up without constant pain and one visit brought instant pain relief. I was so relieved all I could do was cry. I consider this one of the most important things I do to maintain my health and lifestyle.</p>
          <p class="rev-by">— Verified Guest · Google</p>
        </a>
        <article class="rev-c">
          <div class="rev-stars" aria-label="5 out of 5 stars" role="img">★★★★★</div>
          <p class="rev-text">It says a lot about a business when they have employees for over 20 years. My therapist listened carefully and made sure the pressure was right. I left feeling amazing — already looking forward to going back.</p>
          <p class="rev-by">— Verified Guest · Google</p>
        </a>
      </div>
      <p style="text-align:center;margin-top:1.75rem;font-size:.77rem;color:var(--stone)">4.1 ★ average · 136+ reviews on Yelp &amp; Google</p>
    </div>
  </section>

  <!-- VIDEO SECTION -->
  <section style="background:var(--char);padding:4.5rem 0" aria-label="Spa video tour">
    <div class="c">
      <div style="text-align:center;margin-bottom:2.5rem">
        <span class="lbl" style="color:var(--sage-lt)">See Our Spa</span>
        <h2 class="h2" style="color:white">A lakeside retreat<br><em style="color:var(--sage-lt)">in Bellevue</em></h2>
      </div>
      <div style="position:relative;padding-bottom:56.25%;height:0;overflow:hidden;max-width:800px;margin:0 auto">
        <iframe
          style="position:absolute;top:0;left:0;width:100%;height:100%;border:none"
          src="https://www.youtube.com/embed/KuCFONKxQ9M"
          title="All Star Massage and Spa — Bellevue WA on Lake Bellevue"
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen>
        </iframe>
      </div>
    </div>
  </section>

  <section class="sec ins-sec" aria-labelledby="ins-h">
    <div class="c ins-in">
      <div>
        <span class="lbl">Medical Massage Bellevue · Insurance Billing</span>
        <h2 class="h2" id="ins-h">We bill your <em>insurance</em></h2>
        <div class="rule"></div>
        <p class="body-s" style="margin-bottom:1.5rem">Our credentialed medical massage therapists are in-network with most major Bellevue-area insurance plans — making regular therapeutic care genuinely affordable. We also accept PIP and Workers' Compensation.</p>
        <a href="/contact" class="btn btn-p">Verify Your Coverage →</a>
      </div>
      <div>
        <div class="ins-badges" role="list" aria-label="Accepted insurance plans">
          <span class="ins-b" role="listitem">Regence</span>
          <span class="ins-b" role="listitem">Premera</span>
          <span class="ins-b" role="listitem">Blue Cross Blue Shield</span>
          <span class="ins-b" role="listitem">Aetna</span>
          <span class="ins-b" role="listitem">United Healthcare</span>
          <span class="ins-b" role="listitem">Kaiser Permanente</span>
          <span class="ins-b" role="listitem">First Choice</span>
          <span class="ins-b" role="listitem">PIP Claims</span>
          <span class="ins-b" role="listitem">Workers' Compensation</span>
        </div>
        <p class="ins-note">Coverage varies by plan and therapist. Call <a href="tel:4254521772" style="color:var(--sage-dk)">425.452.1772</a> to verify before your first visit.</p>
      </div>
    </div>
  </section>

  <section class="lake" aria-labelledby="loc-h">
    <div class="c lake-in">
      <div>
        <span class="lbl" style="color:var(--sage-lt)">Find Us · Bellevue, WA</span>
        <h2 id="loc-h">Escape to <em style="color:var(--sage-lt)">the lake</em></h2>
        <div class="rule" style="background:var(--sage-lt)"></div>
        <p>Nestled on the shores of Lake Bellevue — minutes from downtown yet a world apart. Unwind in our relaxation room, sip tea, and gaze out at the lake. Serving Bellevue, Kirkland, Issaquah, Mercer Island, Sammamish, Redmond, Newcastle, and Bothell.</p>
        <a href="/contact" class="btn btn-g">Get Directions →</a>
      </div>
      <div class="lake-deets">
        <img src="photos/photo-location.jpg"
          alt="All Star Massage and Spa on Lake Bellevue Bellevue WA" width="600" height="220"
          style="width:100%;height:200px;object-fit:cover;object-position:center 60%;margin-bottom:1.5rem;filter:brightness(.95) saturate(1.1)"
          loading="lazy">
        <div class="ld-i"><div class="ld-ic">📍</div><div><strong>Address</strong><p>9 Lake Bellevue Drive, Suite 112<br>Bellevue, WA 98005</p></div></div>
        <div class="ld-i"><div class="ld-ic">🕐</div><div><strong>Hours</strong><p>Mon &amp; Fri: 9:00 am – 7:00 pm<br>Tue / Wed / Thu: 10:00 am – 9:00 pm<br>Saturday: 9:00 am – 9:00 pm<br>Sunday: Closed</p></div></div>
        <div class="ld-i"><div class="ld-ic">📞</div><div><strong>Phone</strong><p><a href="tel:4254521772" style="color:var(--sage-lt)">425.452.1772</a></p></div></div>
        <div class="ld-i"><div class="ld-ic">🚗</div><div><strong>Parking</strong><p>Free private lot · Easy I-405 &amp; SR-520 access</p></div></div>
      </div>
    </div>
  </section>

  <section class="sec faq-sec" aria-labelledby="faq-h">
    <div class="c">
      <span class="lbl">Common Questions · Massage Bellevue WA</span>
      <h2 class="h2" id="faq-h">Frequently asked about<br><em>massage in Bellevue</em></h2>
      <div class="rule"></div>
      <div class="faq-grid">
        <div class="faq-i"><h3>Does All Star accept health insurance for massage?</h3><p>Yes — we accept Regence, Premera, Blue Cross Blue Shield, Aetna, United Healthcare, Kaiser, and First Choice, as well as PIP and Workers' Comp. Please call your insurance to verify coverage before your visit: <a href="tel:4254521772">425.452.1772</a>.</p></div>
        <div class="faq-i"><h3>Where exactly is the spa in Bellevue?</h3><p>We're at <strong>9 Lake Bellevue Drive, Suite 112, Bellevue, WA 98005</strong> — exclusively on Lake Bellevue with free parking. Just minutes from downtown Bellevue.</p></div>
        <div class="faq-i"><h3>What types of massage do you offer?</h3><p>Medical massage, deep tissue, hot stone, Swedish, sports, prenatal, reflexology, and cupping. All customized to your individual needs by state-licensed therapists.</p></div>
        <div class="faq-i"><h3>How do I book a massage in Bellevue?</h3><p>Book online anytime at our <a href="https://www.secure-booker.com/allstarmassage/MakeAppointment/Search.aspx" target="_blank">secure booking page</a>, or call <a href="tel:4254521772">425.452.1772</a> Mon &amp; Fri 9am–7pm · Tue–Thu 10am–9pm · Sat 9am–9pm. Walk-ins welcome when available.</p></div>
        <div class="faq-i"><h3>Do you offer spa gift certificates?</h3><p>Yes! Instant digital gift certificates for any amount — delivered by email immediately. <a href="/gift">Purchase online 24/7</a>. Perfect for any occasion.</p></div>
        <div class="faq-i"><h3>What Bellevue neighborhoods do you serve?</h3><p>We're conveniently located for guests in Bellevue, Kirkland, Issaquah, Mercer Island, Sammamish, Redmond, Newcastle, and Bothell — all easy access via I-405 and SR-520.</p></div>
      </div>
    </div>
  </section>
  </main>
</Layout>
