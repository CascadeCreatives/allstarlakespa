---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Contact & Hours | All Star Massage and Spa | 425.452.1772"
  description="Contact All Star Massage and Spa at 9 Lake Bellevue Drive Suite 112, Bellevue WA. Call 425.452.1772. Mon & Fri 9am-7pm, Tue-Thu 10am-9pm, Sat 9am-9pm.">
  <main class="page" id="main-content">
<div class="contact-banner">
    <img src="photos/photo-banner-contact.jpg"
      alt="All Star Massage and Spa on Lake Bellevue Bellevue WA contact location" width="1200" height="250" loading="lazy">
    <div class="contact-banner-txt">
      <div>
        <span class="lbl" style="color:var(--sage-lt)">Come find us</span>
        <h1 class="h1" style="color:white">Visit us on<br><em style="color:var(--sage-lt)">Lake Bellevue</em></h1>
      </div>
    </div>
  </div>
  <div class="c contact-grid">
    <div class="ci">
      <div>
        <span class="ci-lbl">Phone</span>
        <div class="ci-big"><a href="tel:4254521772">425.452.1772</a></div>
        <p style="margin-top:.5rem;font-size:.81rem;color:var(--stone)">Appointments encouraged. Walk-ins welcome when available.</p>
      </div>
      <div>
        <span class="ci-lbl">Address</span>
        <p><strong>9 Lake Bellevue Drive, Suite 112</strong><br>Bellevue, WA 98005</p>
        <a href="https://maps.google.com/?q=9+Lake+Bellevue+Drive+Suite+112+Bellevue+WA+98005" target="_blank" rel="noopener" style="display:inline-block;margin-top:.7rem;font-size:.7rem;letter-spacing:.08em;text-transform:uppercase;color:var(--sage-dk);border-bottom:1px solid var(--sage-lt)">Open in Google Maps →</a>
      </div>
      <div>
        <span class="ci-lbl">Hours</span>
        <p>Mon &amp; Fri: 9:00 am – 7:00 pm<br>Tue / Wed / Thu: 10:00 am – 9:00 pm<br>Saturday: 9:00 am – 9:00 pm<br>Sunday: Closed</p>
      </div>
      <div>
        <span class="ci-lbl">Parking &amp; Access</span>
        <p>Free private lot parking. Easy access from I-405 and SR-520. Located in the Lake Bellevue professional complex, minutes from downtown Bellevue.</p>
      </div>
      <div class="cta-box">
        <h3>Ready to book?</h3>
        <p>Schedule online anytime or call during business hours. We'll always do our best to accommodate you.</p>
        <div class="cta-btns">
          <a href="https://www.secure-booker.com/allstarmassage/MakeAppointment/Search.aspx" target="_blank" class="btn" style="background:white;color:var(--sage-dk)">Book Online →</a>
          <a href="https://allstarlakespa.boomtime.com/lgift" target="_blank" class="btn btn-g">Gift Certificates →</a>
        </div>
      </div>
    </div>
    <div>
      <div class="map-w">
        <iframe
          title="All Star Massage and Spa — 9 Lake Bellevue Drive Suite 112 Bellevue WA 98005"
          loading="lazy" allowfullscreen referrerpolicy="no-referrer-when-downgrade"
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2689.882!2d-122.18752!3d47.59802!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x54906c9a2abb8c01%3A0x0!2s9+Lake+Bellevue+Dr+%23112%2C+Bellevue%2C+WA+98005!5e0!3m2!1sen!2sus!4v1700000000000">
        </iframe>
      </div>
      <div class="ins-box2">
        <span class="lbl">Insurance &amp; Billing · Medical Massage Bellevue</span>
        <h3>Covered by most<br><em>major insurance plans</em></h3>
        <div class="ins-badges" role="list">
          <span class="ins-b" role="listitem">Regence</span>
          <span class="ins-b" role="listitem">Premera</span>
          <span class="ins-b" role="listitem">Blue Cross Blue Shield</span>
          <span class="ins-b" role="listitem">Aetna</span>
          <span class="ins-b" role="listitem">United Healthcare</span>
          <span class="ins-b" role="listitem">Kaiser Permanente</span>
          <span class="ins-b" role="listitem">First Choice</span>
          <span class="ins-b" role="listitem">PIP Claims</span>
          <span class="ins-b" role="listitem">Workers' Compensation</span>
        </div>
        <p class="ins-note" style="margin-top:.9rem">Coverage varies by plan. Call to verify: <a href="tel:4254521772" style="color:var(--sage-dk)">425.452.1772</a></p>
      </div>
    </div>
  </div>
  </main>
</Layout>
