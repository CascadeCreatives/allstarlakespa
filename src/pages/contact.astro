---
import Layout from '../layouts/Layout.astro';
import Banner from '../components/Banner.astro';
import InsuranceBadges from '../components/InsuranceBadges.astro';
---
<Layout
  title="Contact & Hours | All Star Massage and Spa | 425.452.1772"
  description="Contact All Star Massage and Spa at 9 Lake Bellevue Drive Suite 112, Bellevue WA. Call 425.452.1772. Mon & Fri 9am-7pm, Tue-Thu 10am-9pm, Sat 9am-9pm.">
  <main class="page" id="main-content">
<Banner image="photos/photo-banner-contact.jpg" imageAlt="All Star Massage and Spa on Lake Bellevue Bellevue WA contact location" label="Come find us" height="250px">
    <h1 class="h1" style="color:white">Visit us on<br><em style="color:var(--sage-lt)">Lake Bellevue</em></h1>
  </Banner>
  <div class="c contact-grid">
    <div class="ci">
      <div>
        <span class="ci-lbl">Phone</span>
        <div class="ci-big"><a href="tel:4254521772">425.452.1772</a></div>
        <p class="ci-note">Appointments encouraged. Walk-ins welcome when available.</p>
      </div>
      <div>
        <span class="ci-lbl">Address</span>
        <p><strong>9 Lake Bellevue Drive, Suite 112</strong><br>Bellevue, WA 98005</p>
        <a href="https://maps.google.com/?q=9+Lake+Bellevue+Drive+Suite+112+Bellevue+WA+98005" target="_blank" rel="noopener" class="ci-map-link">Open in Google Maps →</a>
      </div>
      <div>
        <span class="ci-lbl">Hours</span>
        <p>Mon &amp; Fri: 9:00 am – 7:00 pm<br>Tue / Wed / Thu: 10:00 am – 9:00 pm<br>Saturday: 9:00 am – 9:00 pm<br>Sunday: Closed</p>
      </div>
      <div>
        <span class="ci-lbl">Parking &amp; Access</span>
        <p>Free private lot parking. Easy access from I-405 and SR-520. Located in the Lake Bellevue professional complex, minutes from downtown Bellevue.</p>
      </div>
      <div class="cta-box">
        <h3>Ready to book?</h3>
        <p>Schedule online anytime or call during business hours. We'll always do our best to accommodate you.</p>
        <div class="cta-btns">
          <a href="https://www.secure-booker.com/allstarmassage/MakeAppointment/Search.aspx" target="_blank" class="btn btn-w">Book Online →</a>
          <a href="https://allstarlakespa.boomtime.com/lgift" target="_blank" class="btn btn-g">Gift Certificates →</a>
        </div>
      </div>
    </div>
    <div>
      <div class="map-w">
        <iframe
          title="All Star Massage and Spa — 9 Lake Bellevue Drive Suite 112 Bellevue WA 98005"
          loading="lazy" allowfullscreen referrerpolicy="no-referrer-when-downgrade"
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2689.882!2d-122.18752!3d47.59802!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x54906c9a2abb8c01%3A0x0!2s9+Lake+Bellevue+Dr+%23112%2C+Bellevue%2C+WA+98005!5e0!3m2!1sen!2sus!4v1700000000000">
        </iframe>
      </div>
      <div class="ins-box2">
        <span class="lbl">Insurance &amp; Billing · Medical Massage Bellevue</span>
        <h3>Covered by most<br><em>major insurance plans</em></h3>
        <InsuranceBadges />
      </div>
    </div>
  </div>
  </main>
</Layout>
